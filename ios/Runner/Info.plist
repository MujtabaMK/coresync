<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>CFBundleURLTypes</key>
		<array>
			<dict>
				<key>CFBundleTypeRole</key>
				<string>Editor</string>
				<key>CFBundleURLSchemes</key>
				<array>
					<string>com.googleusercontent.apps.954417312512-cr3t3l29j4jhnmljahrnlqdpu6h6hjt0</string>
				</array>
			</dict>
		</array>
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>CoreSync Go</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>coresync</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<key>UIBackgroundModes</key>
		<array>
			<string>fetch</string>
			<string>remote-notification</string>
		</array>
		<key>FirebaseAppDelegateProxyEnabled</key>
		<false/>
		<key>NSMotionUsageDescription</key>
		<string>This app uses motion sensors to count your steps.</string>
		<key>NSContactsUsageDescription</key>
		<string>CoreSync Go needs access to your contacts to share tasks with people from your phonebook.</string>
		<key>NSCameraUsageDescription</key>
		<string>CoreSync Go needs camera access to scan documents, QR codes, and analyze your food.</string>
		<key>NFCReaderUsageDescription</key>
		<string>CoreSync Go uses NFC to read NFC tags and cards.</string>
		<key>NSPhotoLibraryUsageDescription</key>
		<string>CoreSync Go needs photo library access to select food images for analysis.</string>
		<key>NSSpeechRecognitionUsageDescription</key>
		<string>CoreSync Go uses speech recognition to log food by voice.</string>
		<key>NSMicrophoneUsageDescription</key>
		<string>CoreSync Go needs microphone access to listen when you speak your food.</string>
		<key>NSFaceIDUsageDescription</key>
		<string>CoreSync Go uses Face ID to protect your saved passwords.</string>
		<key>NSHealthShareUsageDescription</key>
		<string>CoreSync Go reads your health data such as step count to track your daily fitness progress.</string>
		<key>NSHealthUpdateUsageDescription</key>
		<string>CoreSync Go saves your workout and step data to Apple Health to keep your fitness records in sync.</string>
		<key>UIStatusBarHidden</key>
		<true/>
		<key>UIViewControllerBasedStatusBarAppearance</key>
		<false/>
	</dict>
</plist>
