rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public lookup: stores only {email, phoneNumber} per user for
    // unauthenticated checks (forgot password, signup phone validation).
    match /user_lookup/{docId} {
      allow read: if true;
      allow create, update: if request.auth != null
                            && request.auth.uid == docId;
      allow delete: if request.auth != null
                    && request.auth.uid == docId;
    }

    // Users: any authenticated user can read (needed for phone lookup when sharing),
    // only the owner can write their own document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;

      // Password sync subcollection: only the owner can read/write
      match /passwords/{docId} {
        allow read, write: if request.auth.uid == userId;
      }

      // Gym data subcollections: only the owner can read/write
      match /gym_attendance/{docId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /gym_memberships/{docId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /gym_water/{docId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /gym_steps/{docId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /medicines/{docId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /gym_food_scans/{docId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /gym_food_tracking/{docId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /gym_workouts/{docId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /gym_sleep/{docId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /gym_calorie_goals/{docId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /habits/{docId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /custom_foods/{docId} {
        allow read, write: if request.auth.uid == userId;
      }

      // Notifications subcollection (legacy)
      match /notifications/{notifId} {
        allow read, update: if request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }

    // Recipes: shared global collection, any authenticated user can read or seed
    match /recipes/{recipeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Top-level notifications: any authenticated user can create, only target can read/update
    match /notifications/{notifId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null
                          && resource.data.targetUid == request.auth.uid;
    }

    // Tasks: owner can do everything; shared users can read and update status.
    match /tasks/{taskId} {
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      allow read:   if request.auth != null;
      allow update: if request.auth != null
                    && (resource.data.ownerId == request.auth.uid
                        || request.auth.uid in resource.data.sharedWith);
      allow delete: if request.auth != null
                    && resource.data.ownerId == request.auth.uid;

      // Comments: owner and shared users can read and create comments.
      match /comments/{commentId} {
        allow read, create: if request.auth != null
                            && (get(/databases/$(database)/documents/tasks/$(taskId)).data.ownerId == request.auth.uid
                                || request.auth.uid in get(/databases/$(database)/documents/tasks/$(taskId)).data.sharedWith);
      }
    }
  }
}